# ── Database ────────────────────────────────────────────────────────────────
# Neon (managed Postgres): copy your connection string from neon.tech dashboard
DATABASE_URL=postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Redis (Celery broker + result backend) ──────────────────────────────────
# Upstash (managed Redis): copy your connection string from upstash.com dashboard
# Note: Upstash uses rediss:// (TLS) — the + is intentional
REDIS_URL=rediss://default:pass@xxx.upstash.io:6379

# ── AI models ───────────────────────────────────────────────────────────────
# Optional — defaults shown. Override to use a local model path.
TMACHINE_IP2P_MODEL=timbrooks/instruct-pix2pix
TMACHINE_WHISPER_MODEL=base

# Required for voice pipeline LLM prompt extraction
OPENAI_API_KEY=sk-...

# ── Scene security ──────────────────────────────────────────────────────────
# Restrict which .ply files the API may open.
# Set to the directory where your .ply files live.
TMACHINE_SCENE_ROOT=/home/user/scenes

# ── File paths ───────────────────────────────────────────────────────────────
PREVIEW_DIR=./previews
LOCK_TIMEOUT=300

# ── Renderer cache ───────────────────────────────────────────────────────────
# Max number of scenes held in GPU memory at once
TMACHINE_RENDERER_CACHE_SIZE=8
